NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_APP_NAME=
# Google Maps JS API key — powers the address selector (Places autocomplete + map
# pin) on the self-register and lead forms. Enable "Maps JavaScript API" and
# "Places API" for the key. Copied from the hub setup; keep the real value only
# in .env.local (never commit it).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Tenant this deployment is bound to. Each per-tenant branch sets its own values.
# Backend resolves tenant on public endpoints (lead capture, self-register) from
# request headers — slug takes precedence over numeric id when both are sent.
# Empty in the template/main branch.
NEXT_PUBLIC_TENANT_SLUG=
NEXT_PUBLIC_TENANT_ID=
